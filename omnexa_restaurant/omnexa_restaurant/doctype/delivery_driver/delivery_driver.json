{
 "actions": [],
 "allow_rename": 1,
 "autoname": "format:DRV-{YYYY}-{#####}",
 "doctype": "DocType",
 "engine": "InnoDB",
 "field_order": [
  "identity_section",
  "driver_name",
  "mobile_no",
  "status",
  "company",
  "branch",
  "control_section",
  "driver_owner"
 ],
 "fields": [
  {
   "fieldname": "identity_section",
   "fieldtype": "Section Break",
   "label": "Driver Identity"
  },
  {
   "fieldname": "driver_name",
   "fieldtype": "Data",
   "label": "Driver Name",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "mobile_no",
   "fieldtype": "Data",
   "label": "Mobile No"
  },
  {
   "fieldname": "status",
   "fieldtype": "Select",
   "label": "Status",
   "options": "Available\nOn Delivery\nOffline",
   "default": "Available",
   "in_list_view": 1
  },
  {
   "fieldname": "company",
   "fieldtype": "Link",
   "label": "Company",
   "options": "Company",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "branch",
   "fieldtype": "Link",
   "label": "Branch",
   "options": "Branch",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "control_section",
   "fieldtype": "Section Break",
   "label": "Control"
  },
  {
   "fieldname": "driver_owner",
   "fieldtype": "Link",
   "label": "Driver Owner",
   "options": "User"
  }
 ],
 "module": "Omnexa Restaurant",
 "name": "Delivery Driver",
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "print": 1,
   "email": 1,
   "export": 1,
   "report": 1,
   "share": 1
  }
 ],
 "track_changes": 1
}
