{
 "actions": [],
 "allow_rename": 1,
 "autoname": "format:RCP-{YYYY}-{#####}",
 "doctype": "DocType",
 "engine": "InnoDB",
 "field_order": ["menu_item", "yield_qty", "preparation_time_mins", "ingredients", "company", "branch", "is_active"],
 "fields": [
  {"fieldname": "menu_item", "fieldtype": "Link", "label": "Menu Item", "options": "Menu Item", "reqd": 1, "in_list_view": 1},
  {"fieldname": "yield_qty", "fieldtype": "Float", "label": "Yield", "default": "1"},
  {"fieldname": "preparation_time_mins", "fieldtype": "Int", "label": "Preparation Time (Mins)", "default": "0"},
  {"fieldname": "ingredients", "fieldtype": "Table", "label": "Ingredients", "options": "Restaurant Recipe Item"},
  {"fieldname": "company", "fieldtype": "Link", "label": "Company", "options": "Company", "reqd": 1},
  {"fieldname": "branch", "fieldtype": "Link", "label": "Branch", "options": "Branch", "reqd": 1},
  {"fieldname": "is_active", "fieldtype": "Check", "label": "Is Active", "default": "1"}
 ],
 "module": "Omnexa Restaurant",
 "name": "Restaurant Recipe",
 "permissions": [{"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "print": 1, "email": 1, "export": 1, "report": 1, "share": 1}],
 "track_changes": 1
}

