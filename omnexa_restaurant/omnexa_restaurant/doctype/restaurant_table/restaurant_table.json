{
 "actions": [],
 "allow_rename": 1,
 "autoname": "format:TBL-{YYYY}-{#####}",
 "doctype": "DocType",
 "engine": "InnoDB",
 "field_order": ["table_number", "floor", "capacity", "status", "qr_code", "company", "branch"],
 "fields": [
  {"fieldname": "table_number", "fieldtype": "Data", "label": "Table Number", "reqd": 1, "in_list_view": 1},
  {"fieldname": "floor", "fieldtype": "Link", "label": "Restaurant Floor", "options": "Restaurant Floor", "reqd": 1},
  {"fieldname": "capacity", "fieldtype": "Int", "label": "Capacity", "default": "2"},
  {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Available\nOccupied\nReserved\nCleaning", "default": "Available", "in_list_view": 1},
  {"fieldname": "qr_code", "fieldtype": "Data", "label": "QR Code"},
  {"fieldname": "company", "fieldtype": "Link", "label": "Company", "options": "Company", "reqd": 1, "in_list_view": 1},
  {"fieldname": "branch", "fieldtype": "Link", "label": "Branch", "options": "Branch", "reqd": 1, "in_list_view": 1}
 ],
 "module": "Omnexa Restaurant",
 "name": "Restaurant Table",
 "permissions": [{"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "print": 1, "email": 1, "export": 1, "report": 1, "share": 1}],
 "track_changes": 1
}

